<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background">

    <!-- Top bar: back | hearts | score -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <Button
            android:id="@+id/back_gameButton"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="@drawable/button_back" />

        <!-- Hearts centered -->
        <TextView
            android:id="@+id/tvHearts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="❤️❤️❤️"
            android:textSize="26sp"
            android:background="@drawable/heart_badge"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <!-- Score badge on right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:background="@drawable/score_badge"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ "
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Element image -->
    <ImageView
        android:id="@+id/imgVIIIA"
        android:layout_width="match_parent"
        android:layout_height="165dp"
        android:scaleType="centerInside" />

    <!-- Answer slots -->
    <GridView
        android:id="@+id/gridViewAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="6dp"
        android:horizontalSpacing="6dp"
        android:verticalSpacing="6dp"
        android:numColumns="auto_fit"
        android:columnWidth="54dp"
        android:scrollbars="none"
        android:stretchMode="columnWidth" />

    <!-- Undo hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="แตะตัวอักษรในช่องคำตอบเพื่อลบออก"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <!-- Suggest letters -->
    <GridView
        android:id="@+id/gridViewSuggest"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:horizontalSpacing="8dp"
        android:verticalSpacing="8dp"
        android:numColumns="auto_fit"
        android:columnWidth="60dp"
        android:scrollbars="none"
        android:stretchMode="columnWidth" />

</LinearLayout>
